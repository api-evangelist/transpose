{
  "description": "Example request to get NFT transfers for a specific collection on Ethereum",
  "method": "GET",
  "url": "https://api.transpose.io/nft/transfers",
  "headers": {
    "X-API-KEY": "YOUR_API_KEY"
  },
  "queryParameters": {
    "chain_id": "ethereum",
